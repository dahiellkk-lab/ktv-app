{
  "name": "ktv-app",
  "version": "1.0.0",
  "description": "KTV 點歌系統桌面應用程式",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win portable",
    "build-mac": "electron-builder --mac",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.ktv.app",
    "productName": "KTV 點歌系統",
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "src/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/icon.icns"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
